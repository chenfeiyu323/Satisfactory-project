# Shared defaults for local docker-compose and cloud deployments.

MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=satisfactory_factory_designer

DB_URL=jdbc:mysql://mysql:3306/satisfactory_factory_designer?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=password

# Comma-separated list of browser origins allowed to call the backend API.
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:80,http://127.0.0.1:80

PORT=8080

# Save sync: backend auto-imports this file on startup when enabled.
APP_SYNC_AUTO_IMPORT_ON_STARTUP=true
APP_SYNC_OVERWRITE_ON_IMPORT=true
APP_SYNC_SAVE_FILE_PATH=/shared/satisfactory-save.json
